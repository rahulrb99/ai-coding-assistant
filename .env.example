# Required
MODEL_PROVIDER=groq
MODEL_NAME=llama-3.3-70b-versatile

# Provider API keys (fill in the one matching your MODEL_PROVIDER)
OPENAI_API_KEY=
GROQ_API_KEY=

# Optional
WORKSPACE_ROOT=.
EXECUTION_MODE=auto

# MCP — External service API keys
TAVILY_API_KEY=

# MCP — Server URLs (leave blank to use default stdio/npx launch)
MCP_TAVILY_URL=
MCP_CONTEXT7_URL=
MCP_RAG_SERVER_URL=
