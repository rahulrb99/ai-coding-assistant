# Required — set MODEL_PROVIDER to: groq | openai | ollama
MODEL_PROVIDER=groq
MODEL_NAME=llama-3.3-70b-versatile

# Provider API keys (fill in the one matching your MODEL_PROVIDER)
OPENAI_API_KEY=
GROQ_API_KEY=

# Ollama (no API key needed — runs locally)
# Install: https://ollama.com/download
# Then: ollama pull llama3.2 && ollama serve
# Set MODEL_PROVIDER=ollama and MODEL_NAME=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Optional
WORKSPACE_ROOT=.
EXECUTION_MODE=auto

# MCP — External service API keys
TAVILY_API_KEY=

# MCP — Server URLs (leave blank to use default stdio/npx launch)
MCP_TAVILY_URL=
MCP_CONTEXT7_URL=
MCP_RAG_SERVER_URL=
